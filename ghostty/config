# Mirrors ~/.config/kitty/kitty.conf (font, padding, cursor, scrollback, keys).
# Theme is driven by nvim terminal-sync.lua → writes current-theme on :colorscheme.

font-family = NRK Mono
font-synthetic-style = bold,italic,bold-italic
font-size = 10

window-padding-x = 10
window-padding-y = 10
window-decoration = false
window-save-state = always

# Match kitty: no GTK header, tabs only show when there are 2+.
gtk-titlebar = false
gtk-tabs-location = top
gtk-wide-tabs = false
gtk-single-instance = true
window-padding-balance = true

cursor-style = bar
cursor-style-blink = false

copy-on-select = clipboard
scrollback-limit = 10000
clipboard-trim-trailing-spaces = true
mouse-hide-while-typing = true
mouse-scroll-multiplier = discrete:10

# Keybindings.
keybind = ctrl+q=unbind
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard

# Splits — new pane.
keybind = ctrl+shift+enter=new_split:auto
keybind = ctrl+shift+d=new_split:right
keybind = ctrl+shift+s=new_split:down

# Splits — directional focus (vim-style; ctrl+alt+arrow collides with GNOME workspaces).
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+j=goto_split:bottom
keybind = ctrl+shift+k=goto_split:top
keybind = ctrl+shift+l=goto_split:right

# Splits — sequential.
keybind = ctrl+shift+bracket_left=goto_split:previous
keybind = ctrl+shift+bracket_right=goto_split:next

# Splits — resize.
keybind = ctrl+shift+alt+h=resize_split:left,10
keybind = ctrl+shift+alt+j=resize_split:down,10
keybind = ctrl+shift+alt+k=resize_split:up,10
keybind = ctrl+shift+alt+l=resize_split:right,10
keybind = ctrl+shift+equal=equalize_splits

# Splits — close + zoom.
keybind = ctrl+shift+w=close_surface
keybind = ctrl+shift+z=toggle_split_zoom

# Tabs.
keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+left=previous_tab
keybind = ctrl+shift+right=next_tab

# Theme: crucible (forge palette). Variants also available: bogfire, kintsugi.
# To resume nvim sync instead, comment `theme` and uncomment `config-file`.
theme = crucible
# config-file = current-theme
