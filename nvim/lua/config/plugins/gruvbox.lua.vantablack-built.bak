-- gruvbox (ellisonleao/gruvbox.nvim) recast as a monochrome grey+black+white
-- theme, transparent over kitty's blurred blueprint wallpaper.
--
-- contrast = "hard"            -> Normal.bg = dark0_hard (#0a0a0a) for opaque panels.
-- transparent_mode = true      -> Normal/SignColumn/etc bg = NONE, so the kitty
--                                 background_image (assets/blueprint-blur.png)
--                                 shows through the editor. Because Normal.bg is
--                                 then nil, terminal-sync.lua skips patching
--                                 kitty's `background` and keeps gruvbox.conf's.
-- terminal_colors = false      -> nvim does NOT export terminal_color_*, so kitty
--                                 ANSI stays the greyscale baseline in
--                                 ~/.config/kitty/gruvbox.conf. The live Normal fg
--                                 + cursor/selection are still overlaid.
-- palette_overrides            -> every gruvbox hue + structural grey remapped to
--                                 neutral greys; the 7 accents are spread across a
--                                 brightness ladder so syntax still separates.

return {
	"ellisonleao/gruvbox.nvim",
	lazy = false,
	priority = 1000,
	config = function()
		require("gruvbox").setup({
			contrast = "hard",
			terminal_colors = false,
			transparent_mode = true,
			palette_overrides = {
				-- backgrounds / structural greys
				dark0_hard = "#0a0a0a",
				dark0 = "#141414",
				dark0_soft = "#1a1a1a",
				dark1 = "#242424",
				dark2 = "#2e2e2e",
				dark3 = "#3a3a3a",
				dark4 = "#4a4a4a",
				gray = "#808080",
				-- foregrounds / light greys
				light0_hard = "#f0f0f0",
				light0 = "#e4e4e4",
				light0_soft = "#dcdcdc",
				light1 = "#d8d8d8",
				light2 = "#c8c8c8",
				light3 = "#b0b0b0",
				light4 = "#9a9a9a",
				-- primary syntax accents (brightness ladder)
				bright_red = "#b0b0b0",
				bright_green = "#c0c0c0",
				bright_yellow = "#d0d0d0",
				bright_blue = "#a0a0a0",
				bright_purple = "#b8b8b8",
				bright_aqua = "#c8c8c8",
				bright_orange = "#d8d8d8",
				-- mid accents
				neutral_red = "#8a8a8a",
				neutral_green = "#9a9a9a",
				neutral_yellow = "#aaaaaa",
				neutral_blue = "#808080",
				neutral_purple = "#949494",
				neutral_aqua = "#a4a4a4",
				neutral_orange = "#b4b4b4",
				-- faded accents (UI / diff fg)
				faded_red = "#6a6a6a",
				faded_green = "#707070",
				faded_yellow = "#787878",
				faded_blue = "#606060",
				faded_purple = "#6e6e6e",
				faded_aqua = "#747474",
				faded_orange = "#7c7c7c",
				-- diff backgrounds
				dark_red = "#2a2a2a",
				dark_green = "#242424",
				dark_aqua = "#262626",
			},
			overrides = {
				-- Re-introduce muted red/green ONLY for diff + git signals; the
				-- rest of the theme stays monochrome. Add = green, delete = red,
				-- change = muted blue-grey so it never competes with add/delete.
				DiffAdd = { bg = "#16271b" },
				DiffDelete = { fg = "#c46b6b", bg = "#271819" },
				DiffChange = { bg = "#1b2026" },
				DiffText = { fg = "#e4e4e4", bg = "#2a3a4a" },
				diffAdded = { fg = "#7fb07f" },
				diffRemoved = { fg = "#c46b6b" },
				diffChanged = { fg = "#7f9bb8" },
				Added = { fg = "#7fb07f" },
				Removed = { fg = "#c46b6b" },
				Changed = { fg = "#7f9bb8" },
				GitSignsAdd = { fg = "#7fb07f" },
				GitSignsChange = { fg = "#7f9bb8" },
				GitSignsDelete = { fg = "#c46b6b" },

				-- Blueprint-cyan signature accent on the otherwise grey base.
				-- Keywords / control flow = cyan; types = lighter cyan. Functions,
				-- variables, strings, etc. stay grey so the accent stays special.
				Statement = { fg = "#2ae8c8" },
				Keyword = { fg = "#2ae8c8" },
				Conditional = { fg = "#2ae8c8" },
				Repeat = { fg = "#2ae8c8" },
				Label = { fg = "#2ae8c8" },
				Exception = { fg = "#2ae8c8" },
				["@keyword"] = { fg = "#2ae8c8" },
				["@keyword.function"] = { fg = "#2ae8c8" },
				["@keyword.return"] = { fg = "#2ae8c8" },
				["@keyword.operator"] = { fg = "#2ae8c8" },
				["@keyword.conditional"] = { fg = "#2ae8c8" },
				["@keyword.repeat"] = { fg = "#2ae8c8" },
				["@keyword.import"] = { fg = "#2ae8c8" },
				["@conditional"] = { fg = "#2ae8c8" },
				["@repeat"] = { fg = "#2ae8c8" },
				["@exception"] = { fg = "#2ae8c8" },
				["@include"] = { fg = "#2ae8c8" },
				Type = { fg = "#79f0d8" },
				StorageClass = { fg = "#79f0d8" },
				Structure = { fg = "#79f0d8" },
				Typedef = { fg = "#79f0d8" },
				["@type"] = { fg = "#79f0d8" },
				["@type.builtin"] = { fg = "#79f0d8" },
				["@type.definition"] = { fg = "#79f0d8" },
				["@namespace"] = { fg = "#79f0d8" },
				["@module"] = { fg = "#79f0d8" },

				-- UI accents.
				Cursor = { fg = "#0a0a0a", bg = "#2ae8c8" },
				Visual = { bg = "#11463d" },
				Search = { fg = "#0a0a0a", bg = "#2ae8c8" },
				IncSearch = { fg = "#0a0a0a", bg = "#a9ffe8" },
				CurSearch = { fg = "#0a0a0a", bg = "#a9ffe8" },
				MatchParen = { fg = "#a9ffe8", bg = "#11463d", bold = true },
				StatusLine = { fg = "#cdf5ec", bg = "#103a33" },
				StatusLineNC = { fg = "#708a96", bg = "#0e1d24" },
				PmenuSel = { fg = "#e8f4fa", bg = "#11463d" },
				CursorLineNr = { fg = "#2ae8c8", bold = true },
			},
		})
		vim.o.background = "dark"
		vim.cmd.colorscheme("gruvbox")
	end,
}
